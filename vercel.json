{
  "rewrites": [
    { "source": "/cn", "destination": "/index.html" },
    { "source": "/en", "destination": "/en.html" },
    { "source": "/zh", "destination": "/index.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/account", "destination": "/account.html" },
    { "source": "/en/knowledge", "destination": "/knowledge/en/index.html" },
    { "source": "/zh/knowledge", "destination": "/knowledge/zh/index.html" },
    { "source": "/en/knowledge/:slug", "destination": "/knowledge/en/:slug.html" },
    { "source": "/zh/knowledge/:slug", "destination": "/knowledge/zh/:slug.html" }
  ]
}
